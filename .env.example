# Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA commite o arquivo .env — ele já está no .gitignore

PORT=3000

# Supabase — pegue em: https://supabase.com > seu projeto > Settings > Database
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.[SEU_ID].supabase.co:5432/postgres

# JWT — gere uma string aleatória longa e segura
JWT_SECRET=substitua_por_uma_chave_secreta_longa
JWT_EXPIRES_IN=7d
